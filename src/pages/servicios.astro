---
import Layout from "../layouts/Layout.astro";
import { productos } from "../utils/productos";
import { planes } from "../utils/planes";
import { serviciosEspecializados } from "../utils/serviciosEspecializados";
---

<Layout>
  <main class="mx-auto py-16 md:py-20 h-full overflow-y-auto">
    <section class="rounded-2xl border border-[#f2b70542] bg-[#0d0d0d8e] px-6 py-10 shadow-[0_22px_54px_rgb(0_0_0/0.3)] md:px-10 w-[min(1120px,92%)] mx-auto mt-6">
      <p class="m-0 text-xs uppercase tracking-[0.2em] text-dorado">Servicios Sparta</p>
      <h1 class="mt-3 font-cinzel text-[clamp(2rem,6vw,3.5rem)] leading-[1.1] text-[#f6efe2]">Conseguir tus metas</h1>
      <p class="mt-5 text-[1.03rem] leading-[1.8] text-[#f6efe2df]">
        Cada repeticion que haces aqui cuenta una historia de valentia. No importa si hoy empiezas desde cero,
        en Sparta Gym caminamos contigo para convertir el cansancio en orgullo, la duda en confianza y tus
        metas en resultados que puedas sentir en tu cuerpo y en tu vida.
      </p>
    </section>

    <section class="mt-12 w-[min(1120px,92%)] mx-auto">
      <h2 class="font-cinzel text-[clamp(1.6rem,4vw,2.4rem)] text-dorado">Planes</h2>
      <p class="mt-2 max-w-[58ch] text-[#f6efe2d9]">Membresias premium con acceso completo para que entrenes con constancia, enfoque y comodidad.</p>
      <div class="mt-6 grid grid-cols-1 gap-5 md:grid-cols-2">
        {
          planes.map((plan, index) => (
            <article class="group relative overflow-hidden rounded-2xl border border-[#f2b70559] bg-[linear-gradient(155deg,rgb(242_183_5/0.2),rgb(13_13_13/0.95)_52%)] p-6 shadow-[0_18px_44px_rgb(0_0_0/0.32)] transition duration-300 hover:-translate-y-1.5 hover:border-[#f2b705] hover:shadow-[0_20px_46px_rgb(242_183_5/0.26)]">
              <div class="pointer-events-none absolute -right-8 -top-8 h-24 w-24 rounded-full bg-[radial-gradient(circle,rgb(242_183_5/0.5),transparent_70%)] blur-lg"></div>
              <p class="m-0 inline-flex rounded-full border border-[#f6efe245] bg-[#f6efe214] px-3 py-1 text-[0.68rem] uppercase tracking-[0.18em] text-[#f6efe2dd]">Membresia {index + 1}</p>
              <h3 class="mt-4 font-cinzel text-[1.55rem] leading-tight text-[#f6efe2]">{plan.nombre}</h3>
              <p class="mt-2 text-[2rem] font-bold leading-none text-dorado">NIO {plan.precio}</p>
              <p class="mt-3 text-sm leading-relaxed text-[#f6efe2dc]">{plan.detalle}</p>
              <p class="mt-4 text-xs uppercase tracking-[0.16em] text-[#f2c230]">Acceso a fuerza, cardio y funcional</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="mt-14 w-[min(1120px,92%)] mx-auto">
      <h2 class="font-cinzel text-[clamp(1.6rem,4vw,2.4rem)] text-dorado">Productos</h2>
      <p class="mt-2 max-w-[62ch] text-[#f6efe2d9]">Vitaminas y suplementos para potenciar tu rendimiento, recuperación y bienestar diario.</p>
      <div class="mt-6 grid grid-cols-1 gap-5 md:grid-cols-2">
        {
          productos.map((producto) => (
            <article class="overflow-hidden rounded-xl border border-[#d9a67357] bg-[#0d0d0dbf] shadow-[0_16px_40px_rgb(0_0_0/0.28)]">
              <img src={producto.imagen} alt={producto.nombre} loading="lazy" class="h-48 w-full object-cover transition duration-500 hover:scale-105" />
              <div class="p-5">
                <p class="m-0 text-xs uppercase tracking-[0.18em] text-[#f6efe2b8]">ID: {producto.id}</p>
                <h3 class="mt-2 font-cinzel text-[1.35rem] leading-tight text-[#f6efe2]">{producto.nombre}</h3>
                <p class="mt-3 text-sm leading-relaxed text-[#f6efe2d8]">{producto.descripcion}</p>
                <p class="mt-4 text-lg font-bold text-dorado">NIO {producto.precio}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="mt-14 mb-12 w-[min(1120px,92%)] mx-auto">
      <div class="rounded-2xl border border-[#f2b70552] bg-[linear-gradient(150deg,rgb(242_183_5/0.15),rgb(13_13_13/0.94)_44%)] px-6 py-8 shadow-[0_22px_48px_rgb(0_0_0/0.33)] md:px-8">
        <p class="m-0 text-xs uppercase tracking-[0.2em] text-[#f6efe2c9]">Nuestro mayor fuerte</p>
        <h2 class="mt-2 font-cinzel text-[clamp(1.9rem,4.8vw,2.9rem)] leading-tight text-dorado">Contamos con un equipo experto que transforma vidas</h2>
        <p class="mt-3 max-w-[66ch] text-[#f6efe2de]">Mas que entrenar, te acompañamos con experiencia real para lograr resultados seguros, sostenibles y adaptados a tu etapa.</p>
      </div>
      <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-3">
        {
          serviciosEspecializados.map((servicio, index) => (
            <article class="group relative overflow-hidden rounded-xl border border-[#f2b7054a] bg-[linear-gradient(180deg,rgb(26_42_58/0.5),rgb(13_13_13/0.92)_72%)] p-5 shadow-[0_14px_36px_rgb(0_0_0/0.28)] transition duration-300 hover:-translate-y-1 hover:border-[#f2b70595] hover:shadow-[0_18px_40px_rgb(242_183_5/0.18)]">
              <div class="pointer-events-none absolute -left-10 -top-10 h-24 w-24 rounded-full bg-[radial-gradient(circle,rgb(242_183_5/0.42),transparent_70%)] blur-lg"></div>
              <p class="m-0 inline-flex rounded-full border border-[#f6efe245] bg-[#f6efe212] px-3 py-1 text-[0.68rem] uppercase tracking-[0.16em] text-[#f6efe2d1]">Fortaleza {index + 1}</p>
              <h3 class="mt-3 font-cinzel text-[1.42rem] leading-tight text-[#f6efe2]">{servicio.titulo}</h3>
              <p class="mt-3 text-sm leading-relaxed text-[#f6efe2dc]">{servicio.contexto}</p>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
