---
import Layout from "../layouts/Layout.astro";

const canales = [
  {
    titulo: "Telefono y WhatsApp",
    detalle: "+505 8866 3083",
    descripcion:
      "Atendemos consultas, reservas de cupo y planes personalizados.",
  },
  {
    titulo: "Ubicacion",
    detalle: "Esteli, Nicaragua",
    descripcion:
      "Visitanos y conoce nuestras areas de fuerza, cardio y funcional.",
  },
  {
    titulo: "Horario de atencion",
    detalle: "Lunes a Sabado, 4:00 AM - 10:00 PM",
    descripcion:
      "Estamos listos para acompanarte desde temprano hasta la noche.",
  },
];
---

<Layout>
  <main class="pb-16 pt-28 md:pt-32 overflow-y-auto h-full">
    <section
      class="rounded-2xl border border-[#f2b7054f] bg-[#0d0d0dae] px-6 py-10 shadow-[0_24px_58px_rgb(0_0_0/0.34)] md:px-10 mx-auto w-[min(1120px,92%)]"
    >
      <p class="m-0 text-xs uppercase tracking-[0.2em] text-dorado">
        Contacto Sparta
      </p>
      <h1
        class="mt-3 font-cinzel text-[clamp(2rem,5.6vw,3.6rem)] leading-[1.1] text-[#f6efe2]"
      >
        Conversemos sobre tu cambio
      </h1>
      <p
        class="mt-5 max-w-[70ch] text-[1.03rem] leading-[1.8] text-[#f6efe2dd]"
      >
        Tu transformacion comienza con una decision. Escribenos para orientarte
        en el mejor plan, resolver tus dudas y ayudarte a dar el primer paso con
        seguridad y motivacion.
      </p>
    </section>

    <section
      class="mt-10 grid grid-cols-1 gap-5 lg:grid-cols-[1.08fr_0.92fr] mx-auto w-[min(1120px,92%)]"
    >
      <article
        class="rounded-2xl border border-[#f2b70557] bg-[linear-gradient(150deg,rgb(242_183_5/0.18),rgb(13_13_13/0.94)_48%)] p-6 shadow-[0_18px_46px_rgb(0_0_0/0.3)] md:p-7"
      >
        <h2 class="font-cinzel text-[clamp(1.5rem,4vw,2.3rem)] text-dorado">
          Envianos tu mensaje
        </h2>
        <p class="mt-2 text-sm leading-relaxed text-[#f6efe2d7]">
          Completa este formulario y te contactamos para recomendarte el mejor
          plan segun tu objetivo.
        </p>

        <form class="mt-6 grid gap-4" id="form-message">
          <label class="grid gap-2">
            <span class="text-sm font-semibold text-[#f6efe2]"
              >Nombre completo</span
            >
            <input
              type="text"
              name="nombre"
              required
              class="w-full rounded-md border border-[#f6efe240] bg-[#f6efe211] px-4 py-3 text-sm text-[#f6efe2] outline-none transition focus:border-dorado focus:ring-2 focus:ring-[#f2b7055c]"
              placeholder="Ej: Maria Lopez"
            />
          </label>

          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <label class="grid gap-2">
              <span class="text-sm font-semibold text-[#f6efe2]">Telefono</span>
              <input
                type="tel"
                name="telefono"
                required
                class="w-full rounded-md border border-[#f6efe240] bg-[#f6efe211] px-4 py-3 text-sm text-[#f6efe2] outline-none transition focus:border-dorado focus:ring-2 focus:ring-[#f2b7055c]"
                placeholder="+505 ..."
              />
            </label>
            <label class="grid gap-2">
              <span class="text-sm font-semibold text-[#f6efe2]"
                >Correo electronico</span
              >
              <input
                type="email"
                name="correo"
                class="w-full rounded-md border border-[#f6efe240] bg-[#f6efe211] px-4 py-3 text-sm text-[#f6efe2] outline-none transition focus:border-dorado focus:ring-2 focus:ring-[#f2b7055c]"
                placeholder="tu@email.com"
              />
            </label>
          </div>

          <label class="grid gap-2">
            <span class="text-sm font-semibold text-[#f6efe2]"
              >Objetivo principal</span
            >
            <select
              name="objetivo"
              class="w-full rounded-md border border-[#f6efe240] bg-[#0d0d0d] px-4 py-3 text-sm text-[#f6efe2] outline-none transition focus:border-dorado focus:ring-2 focus:ring-[#f2b7055c]"
            >
              <option value="">Selecciona una opcion</option>
              <option value="bajar-grasa">Bajar grasa</option>
              <option value="ganar-masa">Ganar masa muscular</option>
              <option value="mejorar-condicion">Mejorar condicion fisica</option
              >
              <option value="bienestar">Bienestar general</option>
            </select>
          </label>

          <label class="grid gap-2">
            <span class="text-sm font-semibold text-[#f6efe2]">Mensaje</span>
            <textarea
              name="mensaje"
              rows="4"
              class="w-full resize-y rounded-md border border-[#f6efe240] bg-[#f6efe211] px-4 py-3 text-sm text-[#f6efe2] outline-none transition focus:border-dorado focus:ring-2 focus:ring-[#f2b7055c]"
              placeholder="Cuentanos que meta quieres alcanzar..."></textarea>
          </label>

          <button
            type="submit"
            class="mt-1 inline-flex items-center justify-center rounded-md bg-[linear-gradient(120deg,#f2b705,#d9a673)] px-5 py-3 text-sm font-bold tracking-[0.03em] text-[#0d0d0d] transition hover:-translate-y-0.5 hover:shadow-[0_10px_24px_rgb(242_183_5/0.34)] cursor-pointer"
            >Quiero informacion</button
          >
        </form>
      </article>

      <aside class="grid gap-4">
        {
          canales.map((canal, index) => (
            <article class="relative overflow-hidden rounded-xl border border-[#d9a67361] bg-[linear-gradient(180deg,rgb(26_42_58/0.5),rgb(13_13_13/0.9)_70%)] p-5 shadow-[0_14px_34px_rgb(0_0_0/0.28)] transition duration-300 hover:-translate-y-1 hover:border-[#f2b7058f]">
              <div class="pointer-events-none absolute -right-10 -top-10 h-24 w-24 rounded-full bg-[radial-gradient(circle,rgb(242_183_5/0.35),transparent_70%)] blur-lg" />
              <p class="m-0 text-xs uppercase tracking-[0.16em] text-[#f6efe2bf]">
                Canal {index + 1}
              </p>
              <h3 class="mt-2 font-cinzel text-[1.3rem] leading-tight text-[#f6efe2]">
                {canal.titulo}
              </h3>
              <p class="mt-2 text-base font-semibold text-dorado">
                {canal.detalle}
              </p>
              <p class="mt-2 text-sm leading-relaxed text-[#f6efe2da]">
                {canal.descripcion}
              </p>
              {canal.titulo.toLowerCase() === "ubicacion" && (
                <button
                  id="maps-btn"
                  class="inline-flex items-center justify-center rounded-md bg-[linear-gradient(120deg,#f2b705,#d9a673)] px-5 py-3 text-sm font-bold tracking-[0.03em] text-[#0d0d0d] transition hover:-translate-y-0.5 hover:shadow-[0_10px_24px_rgb(242_183_5/0.34)] mt-4 cursor-pointer"
                >
                  Cómo llegar
                </button>
              )}
            </article>
          ))
        }
      </aside>
    </section>
  </main>
</Layout>

<script>
  const form = document.getElementById(
    "form-message",
  ) as HTMLFormElement | null;

  document.addEventListener("submit", (e) => {
    if (form && e.target === form) {
      e.preventDefault();

      fetch("https://formsubmit.co/ajax/jorgitomilina@gmail.com", {
        method: "POST",
        body: new FormData(form),
        headers: {
          Accept: "application/json",
        },
      })
        .then((response) => response.json())
        .then((data) => {
          alert(
            "Gracias por tu mensaje. Nos pondremos en contacto contigo pronto para ayudarte a alcanzar tus objetivos en Sparta Gym.",
          );
          form.reset();
        })
        .catch((error) => {
          console.error("Error:", error);
        });
    }
  });

  document.addEventListener("click", (event) => {
    if (event.target instanceof Element && event.target.matches("#maps-btn")) {
      window.open("https://www.google.com/maps?q=13.103659288021237,-86.36280683652798", "_blank");
    }
  });
</script>
