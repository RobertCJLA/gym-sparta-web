---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="mx-auto flex min-h-screen w-[min(980px,92%)] items-center justify-center px-3 pb-10 pt-32">
    <section class="relative w-full max-w-3xl overflow-hidden rounded-2xl border border-[#f2b7055e] bg-[#0d0d0db5] px-6 py-10 text-center shadow-[0_24px_56px_rgb(0_0_0/0.35)] md:px-10 md:py-12">
      <div aria-hidden="true" class="pointer-events-none absolute -left-12 -top-12 h-40 w-40 rounded-full bg-[radial-gradient(circle,rgb(242_183_5/0.45),transparent_70%)] blur-2xl"></div>
      <div aria-hidden="true" class="pointer-events-none absolute -bottom-16 -right-10 h-48 w-48 rounded-full bg-[radial-gradient(circle,rgb(26_42_58/0.62),transparent_70%)] blur-2xl"></div>

      <p class="relative m-0 font-cinzel text-[clamp(4.2rem,14vw,8rem)] leading-none text-dorado">404</p>
      <h1 class="relative mt-2 font-cinzel text-[clamp(1.7rem,5vw,2.7rem)] leading-tight text-[#f6efe2]">Esta ruta no existe en Sparta Gym</h1>
      <p class="relative mx-auto mt-4 max-w-[60ch] text-[1rem] leading-relaxed text-[#f6efe2dd]">
        Parece que tomaste un desvio. No te preocupes: vuelve al inicio para seguir explorando
        nuestros servicios, promociones y planes de entrenamiento.
      </p>

      <div class="relative mt-7 flex flex-wrap items-center justify-center gap-3">
        <a href="/" class="inline-flex items-center justify-center rounded-md bg-[linear-gradient(120deg,#f2b705,#d9a673)] px-5 py-3 text-sm font-bold tracking-[0.04em] text-[#0d0d0d] no-underline transition hover:-translate-y-0.5">Ir al inicio</a>
        <a href="/servicios" class="inline-flex items-center justify-center rounded-md border border-[#f6efe250] bg-[#f6efe212] px-5 py-3 text-sm font-bold tracking-[0.04em] text-[#f6efe2] no-underline transition hover:-translate-y-0.5 hover:border-[#f2b70593]">Ver servicios</a>
      </div>
    </section>
  </main>
</Layout>
